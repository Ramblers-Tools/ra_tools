<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
	<name>com_ra_tools</name>
	<author>East Cheshire Ramblers</author>
	<creationDate>2026-06-25</creationDate>
	<copyright>Copyright (C) East Cheshire Ramblers. All rights reserved.</copyright>
	<license>GNU General Public License version 3 or later; see LICENSE.txt</license>
	<authorEmail>webmaster@bigley.me.uk</authorEmail>
	<authorUrl>https://ramblerseastcheshire.org.uk/</authorUrl>
	<version>1.0.11</version>
	<description>East Cheshire Ramblers tools component.</description>
	<namespace path="src">Ramblers\Component\Ra_tools</namespace>

	<install>
		<sql>
			<file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
		</sql>
	</install>

	<files folder=".">
		<folder>forms</folder>
		<folder>languages</folder>
		<folder>src</folder>
		<folder>tmpl</folder>
	</files>

	<administration>
		<menu link="option=com_ra_tools&amp;view=dashboard">RA Tools</menu>
		<files folder="admin">
			<filename>access.xml</filename>
			<filename>config.xml</filename>
			<filename>index.html</filename>
			<folder>forms</folder>
			<folder>presets</folder>
			<folder>services</folder>
			<folder>sql</folder>
			<folder>src</folder>
			<folder>tmpl</folder>
		</files>
	</administration>

	<updateservers>
		<server type="extension" priority="1" name="RA Tools Updates">https://raw.githubusercontent.com/Ramblers-Tools/com_ra_tools/main/updates/com_ra_tools.xml</server>
	</updateservers>
</extension>
