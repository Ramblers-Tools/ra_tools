<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="3.0" client="site" method="upgrade">
    <name>RA Tools Sidebar</name>
    <author>Ramblers Tools</author>
    <creationDate>2024</creationDate>
    <copyright>2024-2026 Ramblers Tools</copyright>
    <license>GNU General Public License version 3 or later; see LICENSE.txt</license>
    <authorEmail>support@ramblers.tools</authorEmail>
    <authorUrl>https://ramblers.tools</authorUrl>
    <version>4.0.1</version>
    <description>Displays upcoming walks in a sidebar for Ramblers groups</description>
    <changelogurl>https://raw.githubusercontent.com/Ramblers-Tools/ra_tools/main/changelog.xml</changelogurl>
    <updateservers>
        <server type="extension" name="RA Tools Update Server">https://raw.githubusercontent.com/Ramblers-Tools/ra_tools/main/updates/pkg_ra_tools.xml</server>
    </updateservers>
    <namespace>Ramblers\Module\Ra_tools</namespace>
    <files>
        <filename module="mod_ra_tools">mod_ra_tools.php</filename>
        <filename>index.html</filename>
        <folder>tmpl</folder>
    </files>
    <config>
       <fields name="params">
            <fieldset name="basic">
                <field name="note1"
                    type="note"
                    label="For information about this module please visit: https://ramblers.tools and read the Guide to Ramblers Tools"
                />
                <field name="note2" type="note" label="In the Component parameters for Ramblers Tools, two types of Group details are specified: choose which one to use"/>
                 <field name="filter_type" type="radio" default="group" label="Filter type">
                    <option value="group">Filter by Group</option>
                    <option value="radius">Filter by radius</option>
                </field>
                <field name="group_type" type="radio" 
                    showon="filter_type:group"
                    default="single" label="Group type">
                    <option value="single">Use single Group</option>
                    <option value="list">Use the list of Groups</option>
                </field>                       
                <field name="radius" 
                    type="list" 
                    default="25" 
                    label="Search radius (miles)" 
                    showon="filter_type:radius">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="15">15</option>
                    <option value="20">20</option>
                    <option value="25">25</option>
                    <option value="30">30</option>
                    <option value="35">35</option>
                    <option value="40">40</option>
                    <option value="45">45</option>
                    <option value="50">50</option>
                    <option value="55">55</option>
                    <option value="60">60</option>
                    <option value="65">65</option>
                    <option value="70">70</option>
                    <option value="75">75</option>
                    <option value="80">80</option>
                    <option value="85">85</option>
                    <option value="90">90</option>
                    <option value="95">95</option>
                    <option value="100">100</option>
                </field>
                <field name="display_type" type="radio" 
                    default="RJsonwalksStdNextwalks" 
                    label="Type of display">
                    <option value="RJsonwalksStdNextwalks">Next walks</option>
                    <option value="REventCalendar">Calendar of walks</option> 
                </field>    
                <field name="max" 
                    type="text" 
                    default="12" 
                    size="4" 
                    label="Max number of walks to show" 
                    showon="display_type:RJsonwalksStdNextwalks"
                    description="Max number of walks to be shown" 
                />      
                <field name="cancelled" 
                    type="radio" 
                    default="0" 
                    label="Show cancelled walks">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>
            </fieldset>
            <fieldset name="advanced">
                <field name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_MODULE_LAYOUT_DESC"
                />
                <field name="moduleclass_sfx"
                    type="text"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                />
            </fieldset>
        </fields>
    </config>
</extension>
